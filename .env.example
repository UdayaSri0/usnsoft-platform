APP_NAME=USNsoft
APP_ENV=local
APP_KEY=
APP_DEBUG=true
USNSOFT_HTTP_PORT=8080
APP_URL=http://localhost:${USNSOFT_HTTP_PORT}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=usnsoft
DB_USERNAME=usnsoft
DB_PASSWORD=usnsoft_dev_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_TABLE=queue_jobs

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@usnsoft.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

USNSOFT_SUPERADMIN_EMAIL=
USNSOFT_SUPERADMIN_NAME=
USNSOFT_SUPERADMIN_PASSWORD=
USNSOFT_ENFORCE_INTERNAL_MFA=false
USNSOFT_SUSPICIOUS_LOGIN_THRESHOLD=5
USNSOFT_INTERNAL_SESSION_IDLE_TIMEOUT=30
USNSOFT_MFA_ISSUER="${APP_NAME}"
USNSOFT_MFA_CHALLENGE_TIMEOUT_MINUTES=720
USNSOFT_MFA_RECOVERY_CODE_COUNT=8
USNSOFT_SECURITY_HEADERS_ENABLED=true
USNSOFT_SECURITY_FRAME_OPTIONS=SAMEORIGIN
USNSOFT_SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
USNSOFT_SECURITY_PERMISSIONS_POLICY="camera=(), geolocation=(), microphone=(), payment=(), usb=()"
USNSOFT_HSTS_ENABLED=false
USNSOFT_HSTS_MAX_AGE=31536000
USNSOFT_HSTS_INCLUDE_SUBDOMAINS=true
USNSOFT_HSTS_PRELOAD=false
USNSOFT_CSP_REPORT_ONLY=
USNSOFT_ANTI_SPAM_DRIVER=null
USNSOFT_ANTI_SPAM_BLOG_COMMENTS=true
USNSOFT_ANTI_SPAM_CAREERS=true
USNSOFT_ANTI_SPAM_CLIENT_REQUESTS=true
USNSOFT_ANTI_SPAM_HONEYPOT_FIELD=company_website
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
CLIENT_REQUESTS_UPLOAD_DISK=local
USNSOFT_CAREERS_UPLOAD_DISK=local
TRUSTED_PROXIES=
TRUSTED_HOSTS=
USNSOFT_SEED_DEMO_USERS=false

VITE_APP_NAME="${APP_NAME}"
